# 1. Приказываем серверу использовать свежую Node.js версии 20
FROM node:20-alpine

# 2. Создаем рабочую папку для бота внутри сервера
WORKDIR /app

# 3. Сначала копируем только файлы со списками библиотек
COPY package*.json ./

# 4. Устанавливаем библиотеки (теперь ошибок EBADENGINE не будет!)
RUN npm install

# 5. Копируем весь остальной код бота
COPY . .

# 6. Даем жесткую команду на запуск через TypeScript
CMD ["npx", "tsx", "src/app.ts"]
