# 1. Зависимости (Сервер BotHost установит их сам по файлу package.json)
node_modules/

# 2. Секретные ключи и переменные окружения (КРИТИЧЕСКИ ВАЖНО)
.env
.env.*
!.env.example

# 3. Скомпилированный код (Результат работы TypeScript, исходники остаются в src/)
dist/
build/

# 4. Файлы бота и данные клиентов (Защита приватности)
# Бот временно скачивает сметы. Этим файлам не место в репозитории.
*.pdf
temp/
uploads/
downloads/

# 5. Логи ошибок (Чтобы не засорять репозиторий мусором)
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 6. Системные файлы операционных систем (Windows/macOS)
.DS_Store
Thumbs.db